{
  "schemaVersion": 2,
  "name": "chart/meter",
  "type": "chart",
  "description": "Progress meter in bar or gauge variant with threshold coloring.",
  "version": "0.6.4",
  "files": [],
  "dependencies": ["@cascivo/charts"],
  "tags": ["chart", "meter", "gauge", "progress", "data-viz"],
  "category": "chart",
  "install": "@cascivo/charts",

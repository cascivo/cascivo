{
  "name": "cascivo",
  "version": "0.5.3",
  "private": false,
  "description": "CLI — npx cascivo init / add / list / update",
  "keywords": [
    "cascivo",
    "cli",
    "css",
    "design-system",
    "npx",
    "react",
    "signals"
  ],
  "homepage": "https://github.com/cascivo/cascivo/tree/main/packages/cli#readme",
  "bugs": "https://github.com/cascivo/cascivo/issues",
  "license": "MIT",
  "author": "urbanisierung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascivo/cascivo.git",
    "directory": "packages/cli"
  },
  "bin": {
    "cascivo": "./bin/cascivo.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack && node -e \"const fs=require('fs');const f='dist/index.mjs';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)\" && chmod +x dist/index.mjs",
    "check": "tsc --noEmit",
    "test": "vp test",
    "dev": "vp pack --watch"
  },
  "dependencies": {
    "@cascivo/registry": "workspace:^"
  },
  "devDependencies": {
    "@cascivo/theme-kit": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}

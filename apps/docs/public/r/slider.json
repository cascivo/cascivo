        "type": "number",
        "required": false
      },
      {
        "name": "defaultValue",
        "type": "number",
        "required": false
      },
      {
        "name": "disabled",
        "type": "boolean",
        "required": false,
        "default": "false"
      }
    ],
    "tokens": [
      "--cascade-color-accent",
      "--cascade-color-border-strong",
      "--cascade-color-surface",
      "--cascade-radius-full",
      "--cascade-focus-ring"

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "../..",
    "outDir": "./dist/types"
  },
  "include": ["src", "../components/src"],
  "exclude": [
    "../components/src/**/*.test.tsx",
    "../components/src/**/*.test.ts",
    "../components/src/setup.ts",
    "../components/src/test-utils",
    "src/**/*.test.tsx",
    "src/**/*.test.ts"
  ]
}

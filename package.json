{
  "name": "@cascivo/monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "urbanisierung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascivo/cascivo.git"
  },
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "build:landing-demos": "vp run @cascivo/site#build && node scripts/assemble-demos.mjs --build",
    "screenshots:generate": "node scripts/gen-demo-screenshots.mjs",
    "test": "vp run -r test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "audit:animation": "node scripts/quality/animation-audit.ts",
    "audit:bundle": "node scripts/quality/bundle-check.ts",
    "audit:landing": "node scripts/quality/landing-budget.ts",
    "links:check": "node scripts/quality/landing-links.ts",
    "audit:treeshake": "pnpm --filter bench-runner bench treeshake",
    "bench": "pnpm --filter bench-runner bench all",
    "audit:stories": "node scripts/quality/story-check.ts",
    "audit:signals": "bash scripts/checks/use-signals-gate.sh",
    "fallback:check": "node scripts/checks/css-fallback.ts packages/components/src packages/tokens/src packages/flow/src packages/themes/src",
    "apg:check": "node --experimental-strip-types --test scripts/checks/apg.test.ts",
    "screens:check": "node --experimental-strip-types --test packages/tokens/src/screens.test.ts",
    "breakpoint:check": "node --experimental-strip-types --test scripts/checks/breakpoint.test.ts",
    "claims:check": "node --experimental-strip-types --test scripts/checks/claims.test.ts scripts/checks/bench-stats.test.ts scripts/checks/md-tables.test.ts",
    "release:check": "node --experimental-strip-types --test scripts/checks/release-filter.test.ts",
    "meta:check": "node --experimental-strip-types --test scripts/checks/meta-coverage.test.ts scripts/checks/manifest-completeness.test.ts",
    "brand:check": "node scripts/brand-guard.mjs",
    "demos:storage:check": "node --experimental-strip-types --test scripts/checks/demo-storage-keys.test.ts",
    "deps:check": "node scripts/registry/deps-check.ts",
    "deps:smoke": "node scripts/registry/standalone-smoke.ts",
    "deps:check:test": "node --experimental-strip-types --test scripts/registry/deps-check.test.ts",
    "docs:coverage": "node scripts/registry/docs-coverage.ts",
    "llms:generate": "node scripts/llms/generate.ts",
    "sitemap:generate": "node scripts/sitemap/generate.ts",
    "blog-feed:generate": "node scripts/blog-feed/generate.ts",
    "registry:generate": "node scripts/registry/generate.ts",
    "stories:generate": "node scripts/stories/generate.ts",
    "readme:index": "node scripts/readme/component-index.mjs",
    "readme:generate": "node scripts/readme/generate.ts",
    "catalog:generate": "node scripts/catalog/generate.ts",
    "variants:generate": "node scripts/variants/generate.ts",
    "context:generate": "node scripts/context/generate.ts",
    "changes:generate": "node scripts/changes/generate.ts",
    "parity:generate": "node scripts/parity/generate.ts",
    "migration:generate": "node scripts/migration/generate.ts",
    "simplicity:generate": "node scripts/simplicity/generate.ts",
    "specs:generate": "node scripts/specs/generate.ts",
    "schema:generate": "node scripts/schema/generate.ts",
    "tokens:generate": "node scripts/tokens/generate-manifest.mjs",
    "icons:generate": "node scripts/icons/generate.mjs",
    "regen": "pnpm registry:generate && pnpm deps:check && pnpm icons:generate && pnpm stories:generate && pnpm schema:generate && pnpm catalog:generate && pnpm variants:generate && pnpm specs:generate && pnpm context:generate && pnpm changes:generate && pnpm parity:generate && pnpm migration:generate && pnpm simplicity:generate && pnpm tokens:generate && pnpm readme:index && pnpm readme:generate && pnpm llms:generate && pnpm sitemap:generate && pnpm blog-feed:generate",
    "dev:docs": "vp run @cascivo/site#dev",
    "dev:landing": "vp run @cascivo/site#dev",
    "dev:landing:full": "vp run -F @cascivo/example-deploy -F @cascivo/example-pay -F @cascivo/example-flow -F @cascivo/example-track -F @cascivo/example-pulse -F @cascivo/example-trade build && vp run @cascivo/site#dev",
    "clean": "find packages apps -maxdepth 3 -name dist -type d -not -path '*/node_modules/*' -exec rm -rf {} + ; vp cache clean",
    "ready": "pnpm regen && vp check --fix && pnpm brand:check && pnpm claims:check && pnpm release:check && pnpm meta:check && vp run -r build && vp run -r check && vp run -r test",
    "ready:ci": "pnpm clean && pnpm regen && vp check --fix && pnpm brand:check && pnpm claims:check && pnpm release:check && pnpm meta:check && vp run -r --concurrency-limit 1 build && vp run -r check && vp run -r test",
    "changeset": "changeset && pnpm check:fix",
    "version-packages": "changeset version && pnpm install --no-frozen-lockfile && pnpm regen",
    "build:release": "vp run --concurrency-limit 1 -F @cascivo/ai -F @cascivo/core -F @cascivo/editor -F @cascivo/flow -F @cascivo/i18n -F @cascivo/icons -F @cascivo/charts -F @cascivo/mcp -F @cascivo/react -F @cascivo/registry -F @cascivo/storage -F @cascivo/themes -F @cascivo/tokens -F cascivo build",
    "release": "pnpm build:release && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@playwright/test": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.8.0"
}

{
  "name": "@cascivo/ai",
  "version": "0.2.0",
  "description": "AI-native components for cascivo — StreamingText, AiLabel, Terminal, AiChat",
  "keywords": [
    "ai",
    "cascivo",
    "chat",
    "css",
    "design-system",
    "react",
    "signals",
    "streaming"
  ],
  "homepage": "https://github.com/cascivo/cascivo/tree/main/packages/ai#readme",
  "license": "MIT",
  "author": "urbanisierung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascivo/cascivo.git",
    "directory": "packages/ai"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "check": "tsc --noEmit",
    "test": "vp test",
    "dev": "vp pack --watch"
  },
  "dependencies": {
    "@cascivo/core": "workspace:^",
    "@cascivo/i18n": "workspace:^",
    "@cascivo/tokens": "workspace:^"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@preact/signals-react": ">=2.0.0",
    "react": ">=18.0.0"
  }
}

{
  "schemaVersion": 2,
  "name": "select",
  "type": "component",
  "description": "Native select menu styled to match the design system",
  "category": "inputs",
  "version": "0.0.0",
  "files": [
    {
      "url": "https://raw.githubusercontent.com/urbanisierung/cascade-ui/main/packages/components/src/select/select.tsx"
    },
    {
      "url": "https://raw.githubusercontent.com/urbanisierung/cascade-ui/main/packages/components/src/select/select.module.css"
    }
  ],
  "dependencies": ["@cascade-ui/core"],
  "tags": ["form", "dropdown", "menu"],
  "meta": {
    "name": "Select",
    "description": "Native select menu styled to match the design system",
    "category": "inputs",
    "states": ["idle", "focused", "error"],
    "variants": [],
    "sizes": ["sm", "md", "lg"],
    "props": [
      {
        "name": "label",
        "type": "string",
        "required": false
      },
      {
        "name": "hint",
        "type": "string",
        "required": false
      },
      {
        "name": "error",
        "type": "string",
        "required": false
      },
      {
        "name": "placeholder",
        "type": "string",
        "required": false
      },
      {
        "name": "options",
        "type": "{ value: string; label: string; disabled?: boolean }[]",
        "required": true
      },
      {
        "name": "size",
        "type": "'sm' | 'md' | 'lg'",
        "required": false,
        "default": "md"
      },
      {
        "name": "disabled",
        "type": "boolean",
        "required": false,
        "default": "false"
      }
    ],
    "tokens": [
      "--cascade-color-surface",
      "--cascade-color-border",
      "--cascade-color-accent",
      "--cascade-color-text-muted",
      "--cascade-radius-input",
      "--cascade-focus-ring"
    ],
    "accessibility": {
      "role": "combobox",
      "wcag": "AA",
      "keyboard": ["Tab", "Space", "ArrowUp", "ArrowDown"]
    },
    "examples": [
      {
        "title": "Basic",
        "code": "<Select label=\"Role\" options={[{ value: \"admin\", label: \"Admin\" }]} />"
      },
      {
        "title": "With placeholder",
        "code": "<Select label=\"Country\" placeholder=\"Choose…\" options={countries} />"
      }
    ],
    "dependencies": ["@cascade-ui/core"],
    "tags": ["form", "dropdown", "menu"]
  }
}

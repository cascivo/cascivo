{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "react": ["./node_modules/preact/compat"],
      "react-dom": ["./node_modules/preact/compat"],
      "react/jsx-runtime": ["./node_modules/preact/jsx-runtime/src/index.d.ts"],
      "react/jsx-dev-runtime": ["./node_modules/preact/jsx-runtime/src/index.d.ts"],
      "preact/jsx-runtime": ["./node_modules/preact/jsx-runtime/src/index.d.ts"],
      "preact/jsx-dev-runtime": ["./node_modules/preact/jsx-runtime/src/index.d.ts"],
      "@cascade-ui/components/button": ["./src/shims/button.d.ts"],
      "@cascade-ui/components/input": ["./src/shims/input.d.ts"],
      "@cascade-ui/components/card": ["./src/shims/card.d.ts"],
      "@cascade-ui/components/badge": ["./src/shims/badge.d.ts"],
      "@cascade-ui/components/modal": ["./src/shims/modal.d.ts"],
      "@cascade-ui/components/spinner": ["./src/shims/spinner.d.ts"],
      "@cascade-ui/components/separator": ["./src/shims/separator.d.ts"],
      "@cascade-ui/components/alert": ["./src/shims/alert.d.ts"],
      "@cascade-ui/components/avatar": ["./src/shims/avatar.d.ts"],
      "@cascade-ui/components/textarea": ["./src/shims/textarea.d.ts"],
      "@cascade-ui/components/select": ["./src/shims/select.d.ts"],
      "@cascade-ui/components/checkbox": ["./src/shims/checkbox.d.ts"],
      "@cascade-ui/components/radio": ["./src/shims/radio.d.ts"],
      "@cascade-ui/components/toggle": ["./src/shims/toggle.d.ts"],
      "@cascade-ui/components/slider": ["./src/shims/slider.d.ts"],
      "@cascade-ui/components/tooltip": ["./src/shims/tooltip.d.ts"],
      "@cascade-ui/components/dropdown": ["./src/shims/dropdown.d.ts"],
      "@cascade-ui/components/toast": ["./src/shims/toast.d.ts"],
      "@cascade-ui/components/tabs": ["./src/shims/tabs.d.ts"],
      "@cascade-ui/components/accordion": ["./src/shims/accordion.d.ts"]
    }
  },
  "include": ["src"]
}

{
  "name": "@cascivo/storybook",
  "version": "0.0.0",
  "private": true,
  "description": "Storybook stories generated from cascivo component manifests",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "check": "tsc --noEmit",
    "test": "echo 'storybook: no tests yet'"

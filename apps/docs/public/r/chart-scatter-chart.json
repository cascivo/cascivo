        "type": "number",
        "required": false
      },
      {
        "name": "height",
        "type": "number",
        "required": false,
        "default": "300"
      },
      {
        "name": "xTicks",
        "type": "number",
        "required": false,
        "default": "5"
      },
      {
        "name": "yTicks",
        "type": "number",
        "required": false,
        "default": "5"
      },
      {

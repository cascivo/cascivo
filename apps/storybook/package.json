    "@cascivo/icons": "workspace:*",
    "@cascivo/layouts": "workspace:*",
    "@cascivo/themes": "workspace:*",
    "@cascivo/tokens": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}

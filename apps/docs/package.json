{
  "name": "@cascivo/site",
  "version": "0.0.0",
  "private": true,
  "description": "cascivo site — the unified front door (cascivo.com) and docs, generated from component manifests",
  "type": "module",
  "scripts": {
    "predev": "node -e \"require('fs').copyFileSync('../../registry.json', 'public/registry.json')\"",
    "dev": "vp dev",
    "prebuild": "node -e \"require('fs').copyFileSync('../../registry.json', 'public/registry.json')\"",
    "build": "vp build",
    "preview": "vp preview",
    "check": "tsc --noEmit",
    "test": "echo 'site: no unit tests yet'",
    "test:visual": "playwright test",
    "test:perf": "playwright test perf.spec.ts",
    "og:generate": "vp preview --port 4180 --strictPort & sleep 3 && node scripts/gen-og.mjs; kill %1",
    "icons:generate": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@cascivo/ai": "workspace:*",
    "@cascivo/charts": "workspace:*",
    "@cascivo/components": "workspace:*",
    "@cascivo/core": "workspace:*",
    "@cascivo/editor": "workspace:*",
    "@cascivo/flow": "workspace:*",
    "@cascivo/i18n": "workspace:*",
    "@cascivo/icons": "workspace:*",
    "@cascivo/layouts": "workspace:*",
    "@cascivo/react": "workspace:*",
    "@cascivo/registry": "workspace:*",
    "@cascivo/render": "workspace:*",
    "@cascivo/search": "workspace:*",
    "@cascivo/storage": "workspace:^",
    "@cascivo/themes": "workspace:*",
    "@cascivo/tokens": "workspace:*",
    "preact": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "shiki": "catalog:",
    "typescript": "catalog:",
    "vite-imagetools": "catalog:",
    "vite-plus": "catalog:"
  }
}

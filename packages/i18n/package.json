{
  "name": "@cascivo/i18n",
  "version": "0.2.9",
  "private": false,
  "description": "Signal-driven locale store, typed message catalogs, and Intl-based formatting for cascivo",
  "keywords": [
    "cascivo",
    "css",
    "design-system",
    "i18n",
    "internationalization",
    "intl",
    "react",
    "signals"
  ],
  "homepage": "https://github.com/cascivo/cascivo/tree/main/packages/i18n#readme",
  "bugs": "https://github.com/cascivo/cascivo/issues",
  "license": "MIT",
  "author": "urbanisierung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascivo/cascivo.git",
    "directory": "packages/i18n"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "check": "tsc --noEmit",
    "test": "vp test",
    "dev": "vp pack --watch"
  },
  "dependencies": {
    "@cascivo/core": "workspace:^"
  },
  "devDependencies": {
    "@preact/signals-react": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@preact/signals-react": ">=3.0.0"
  }
}

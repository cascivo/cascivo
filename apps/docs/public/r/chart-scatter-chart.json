{
  "schemaVersion": 2,
  "name": "chart/scatter-chart",
  "type": "chart",
  "description": "Scatter plot with variable point radius, multi-series, and hover tooltip.",
  "version": "0.0.0",
  "files": [],
  "dependencies": ["@cascade-ui/charts"],
  "tags": ["chart", "scatter", "plot", "data-viz"],
  "category": "chart",
  "install": "@cascade-ui/charts",
  "meta": {
    "name": "ScatterChart",
    "description": "Scatter plot with variable point radius, multi-series, and hover tooltip.",
    "category": "chart",
    "states": [],
    "variants": [],
    "sizes": [],
    "props": [
      {
        "name": "series",
        "type": "ScatterChartSeries[]",
        "required": true
      },
      {
        "name": "title",
        "type": "string",
        "required": true
      },
      {
        "name": "description",

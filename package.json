{
  "name": "@cascade-ui/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "test": "vp run -r test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "audit:animation": "node scripts/quality/animation-audit.ts",
    "audit:bundle": "node scripts/quality/bundle-check.ts",
    "audit:landing": "node scripts/quality/landing-budget.ts",
    "audit:treeshake": "pnpm --filter bench-runner bench treeshake",
    "bench": "pnpm --filter bench-runner bench all",
    "audit:stories": "node scripts/quality/story-check.ts",
    "audit:signals": "bash scripts/checks/use-signals-gate.sh",
    "fallback:check": "node scripts/checks/css-fallback.ts packages/components/src packages/tokens/src",
    "llms:generate": "node scripts/llms/generate.ts",
    "registry:generate": "node scripts/registry/generate.ts",
    "readme:generate": "node scripts/readme/generate.ts",
    "catalog:generate": "node scripts/catalog/generate.ts",
    "context:generate": "node scripts/context/generate.ts",
    "specs:generate": "node scripts/specs/generate.ts",
    "schema:generate": "node scripts/schema/generate.ts",
    "regen": "pnpm registry:generate && pnpm catalog:generate && pnpm specs:generate && pnpm context:generate && pnpm readme:generate && pnpm llms:generate",
    "dev:docs": "vp run @cascade-ui/docs#dev",
    "dev:landing": "vp run @cascade-ui/landing#dev",
    "ready": "vp check && vp run -r check && vp run -r test && vp run -r build",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --no-frozen-lockfile",
    "release": "vp run -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.2"
}

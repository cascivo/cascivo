{
  "name": "@cascivo/render",
  "version": "0.0.0",
  "private": true,
  "description": "Runtime JSON → UI renderer for cascivo",
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "check": "tsc --noEmit",
    "test": "vp test",
    "dev": "vp pack --watch"
  },
  "dependencies": {
    "@cascivo/core": "workspace:^",
    "@cascivo/i18n": "workspace:^",
    "@cascivo/react": "workspace:^"
  },
  "devDependencies": {
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@preact/signals-react": ">=2.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}

{
  "name": "@cascivo/mcp",
  "version": "0.3.2",
  "private": false,
  "description": "MCP server exposing the cascivo component registry to AI agents",
  "keywords": [
    "ai",
    "cascivo",
    "css",
    "design-system",
    "mcp",
    "model-context-protocol",
    "react",
    "signals"
  ],
  "homepage": "https://github.com/cascivo/cascivo/tree/main/packages/mcp#readme",
  "bugs": "https://github.com/cascivo/cascivo/issues",
  "license": "MIT",
  "author": "urbanisierung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascivo/cascivo.git",
    "directory": "packages/mcp"
  },
  "bin": {
    "cascade-mcp": "./dist/index.mjs",
    "cascivo-mcp": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack && node scripts/postbuild.mjs",
    "check": "tsc --noEmit",
    "test": "vp test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}

{
  "name": "@cascivo/vite-plugin",
  "version": "0.1.0",
  "private": false,
  "description": "Vite plugin — wrap JS-imported third-party stylesheets into a low-priority CSS @layer",
  "keywords": [
    "cascivo",
    "css",
    "css-layers",
    "vendor",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/cascivo/cascivo/tree/main/packages/vite-plugin#readme",
  "bugs": "https://github.com/cascivo/cascivo/issues",
  "license": "MIT",
  "author": "urbanisierung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascivo/cascivo.git",
    "directory": "packages/vite-plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "check": "tsc --noEmit",
    "test": "vp test"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}

{
  "name": "@cascivo/icons",
  "version": "0.3.1",
  "private": false,
  "description": "Optional SVG icon components",
  "keywords": [
    "cascivo",
    "css",
    "design-system",
    "icons",
    "react",
    "signals",
    "svg"
  ],
  "homepage": "https://github.com/cascivo/cascivo/tree/main/packages/icons#readme",
  "bugs": "https://github.com/cascivo/cascivo/issues",
  "license": "MIT",
  "author": "urbanisierung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascivo/cascivo.git",
    "directory": "packages/icons"
  },
  "files": [
    "dist",
    "src/glyphs.css"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./glyphs.css": "./src/glyphs.css"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack src/index.tsx",
    "check": "tsc --noEmit",
    "test": "vp test"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
